# .env.example — 필요한 환경변수의 '이름'만 문서화한다.
#
# 이 파일은 git 에 커밋된다. 따라서 실제 키 값을 여기 적지 마라.
# 각 키는 아래 발급처에서 직접 받아 프로젝트 루트의 .env 에 채운다.
# (.env 는 .gitignore 로 추적 제외되어 커밋되지 않는다.)

# 네이버 뉴스 검색 API — 뉴스 중립 수집
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Anthropic Claude API — 뉴스 판단(LLM)
ANTHROPIC_API_KEY=

# OpenDART API — 계정과목 목록 + 재무 규모(분모)
OPENDART_API_KEY=
